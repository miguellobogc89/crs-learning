generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider = "postgresql"
}

model achievements {
  id                String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code              String              @unique
  title             String
  description       String?
  xp_reward         Int                 @default(0)
  icon              String?
  created_at        DateTime            @default(now()) @db.Timestamptz(6)
  user_achievements user_achievements[]
}

model courses {
  id                   String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title                String
  slug                 String                 @unique
  description          String?
  level                String                 @default("beginner")
  is_published         Boolean                @default(false)
  sort_order           Int                    @default(0)
  required_course_id   String?                @db.Uuid
  created_at           DateTime               @default(now()) @db.Timestamptz(6)
  updated_at           DateTime               @default(now()) @db.Timestamptz(6)
  knowledge_source_id  String?                @db.Uuid
  knowledge_sources    knowledge_sources?     @relation(fields: [knowledge_source_id], references: [id], onUpdate: NoAction)
  courses              courses?               @relation("coursesTocourses", fields: [required_course_id], references: [id], onUpdate: NoAction)
  other_courses        courses[]              @relation("coursesTocourses")
  sections             sections[]
  user_course_progress user_course_progress[]

  @@index([knowledge_source_id], map: "idx_courses_knowledge_source_id")
}

model lessons {
  id                   String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  module_id            String                 @db.Uuid
  title                String
  content              String
  lesson_type          String                 @default("reading")
  estimated_minutes    Int                    @default(5)
  sort_order           Int                    @default(0)
  created_at           DateTime               @default(now()) @db.Timestamptz(6)
  updated_at           DateTime               @default(now()) @db.Timestamptz(6)
  sections             sections               @relation(fields: [module_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  quizzes              quizzes[]
  section_items        section_items?
  user_lesson_progress user_lesson_progress[]

  @@index([module_id], map: "idx_lessons_module_id")
}

model question_options {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  question_id String    @db.Uuid
  option_text String
  is_correct  Boolean   @default(false)
  sort_order  Int       @default(0)
  questions   questions @relation(fields: [question_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model questions {
  id               String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  quiz_id          String             @db.Uuid
  question_text    String
  question_type    String             @default("single_choice")
  explanation      String?
  sort_order       Int                @default(0)
  created_at       DateTime           @default(now()) @db.Timestamptz(6)
  question_options question_options[]
  quizzes          quizzes            @relation(fields: [quiz_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([quiz_id], map: "idx_questions_quiz_id")
}

model quiz_attempts {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id      String    @db.Uuid
  quiz_id      String    @db.Uuid
  score        Int       @default(0)
  passed       Boolean   @default(false)
  started_at   DateTime  @default(now()) @db.Timestamptz(6)
  completed_at DateTime? @db.Timestamptz(6)
  quizzes      quizzes   @relation(fields: [quiz_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users        users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([user_id], map: "idx_quiz_attempts_user_id")
}

model quizzes {
  id                 String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  lesson_id          String?         @db.Uuid
  title              String
  passing_score      Int             @default(70)
  max_attempts       Int?
  time_limit_seconds Int?
  created_at         DateTime        @default(now()) @db.Timestamptz(6)
  updated_at         DateTime        @default(now()) @db.Timestamptz(6)
  section_id         String?         @db.Uuid
  questions          questions[]
  quiz_attempts      quiz_attempts[]
  lessons            lessons?        @relation(fields: [lesson_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  sections           sections?       @relation(fields: [section_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  section_items      section_items?

  @@index([lesson_id], map: "idx_quizzes_lesson_id")
}

model user_achievements {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id        String       @db.Uuid
  achievement_id String       @db.Uuid
  unlocked_at    DateTime     @default(now()) @db.Timestamptz(6)
  achievements   achievements @relation(fields: [achievement_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users          users        @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([user_id, achievement_id])
}

model user_course_progress {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id          String    @db.Uuid
  course_id        String    @db.Uuid
  status           String    @default("pending")
  progress_percent Int       @default(0)
  started_at       DateTime? @db.Timestamptz(6)
  completed_at     DateTime? @db.Timestamptz(6)
  suspended_at     DateTime? @db.Timestamptz(6)
  created_at       DateTime  @default(now()) @db.Timestamptz(6)
  updated_at       DateTime  @default(now()) @db.Timestamptz(6)
  courses          courses   @relation(fields: [course_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users            users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([user_id, course_id])
  @@index([user_id], map: "idx_user_course_progress_user_id")
}

model user_lesson_progress {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id      String    @db.Uuid
  lesson_id    String    @db.Uuid
  status       String    @default("pending")
  completed_at DateTime? @db.Timestamptz(6)
  created_at   DateTime  @default(now()) @db.Timestamptz(6)
  updated_at   DateTime  @default(now()) @db.Timestamptz(6)
  lessons      lessons   @relation(fields: [lesson_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users        users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([user_id, lesson_id])
  @@index([user_id], map: "idx_user_lesson_progress_user_id")
}

model users {
  id                                                                                      String                          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email                                                                                   String                          @unique
  name                                                                                    String?
  image                                                                                   String?
  provider                                                                                String?                         @default("credentials")
  xp                                                                                      Int                             @default(0)
  level                                                                                   Int                             @default(1)
  status                                                                                  String                          @default("active")
  created_at                                                                              DateTime                        @default(now()) @db.Timestamptz(6)
  updated_at                                                                              DateTime                        @default(now()) @db.Timestamptz(6)
  company_id                                                                              String?                         @db.Uuid
  chat_conversations_chat_conversations_created_by_user_idTousers                         chat_conversations[]            @relation("chat_conversations_created_by_user_idTousers")
  chat_conversations_chat_conversations_owner_user_idTousers                              chat_conversations[]            @relation("chat_conversations_owner_user_idTousers")
  chat_conversations_chat_conversations_updated_by_user_idTousers                         chat_conversations[]            @relation("chat_conversations_updated_by_user_idTousers")
  chat_messages                                                                           chat_messages[]
  knowledge_activity                                                                      knowledge_activity[]
  knowledge_correction_requests_knowledge_correction_requests_assigned_to_user_idTousers  knowledge_correction_requests[] @relation("knowledge_correction_requests_assigned_to_user_idTousers")
  knowledge_correction_requests_knowledge_correction_requests_requested_by_user_idTousers knowledge_correction_requests[] @relation("knowledge_correction_requests_requested_by_user_idTousers")
  knowledge_events                                                                        knowledge_events[]
  knowledge_files                                                                         knowledge_files[]
  knowledge_imports                                                                       knowledge_imports[]
  knowledge_libraries_knowledge_libraries_created_by_user_idTousers                       knowledge_libraries[]           @relation("knowledge_libraries_created_by_user_idTousers")
  knowledge_libraries                                                                     knowledge_libraries[]
  knowledge_libraries_knowledge_libraries_updated_by_user_idTousers                       knowledge_libraries[]           @relation("knowledge_libraries_updated_by_user_idTousers")
  knowledge_library_permissions                                                           knowledge_library_permissions[]
  knowledge_notifications                                                                 knowledge_notifications[]
  knowledge_share_links                                                                   knowledge_share_links[]
  knowledge_sources_knowledge_sources_created_by_user_idTousers                           knowledge_sources[]             @relation("knowledge_sources_created_by_user_idTousers")
  knowledge_sources_knowledge_sources_updated_by_user_idTousers                           knowledge_sources[]             @relation("knowledge_sources_updated_by_user_idTousers")
  knowledge_space_permissions                                                             knowledge_space_permissions[]
  knowledge_spaces_knowledge_spaces_created_by_user_idTousers                             knowledge_spaces[]              @relation("knowledge_spaces_created_by_user_idTousers")
  knowledge_spaces_knowledge_spaces_updated_by_user_idTousers                             knowledge_spaces[]              @relation("knowledge_spaces_updated_by_user_idTousers")
  knowledge_team_members                                                                  knowledge_team_members[]
  knowledge_teams                                                                         knowledge_teams[]
  quiz_attempts                                                                           quiz_attempts[]
  user_achievements                                                                       user_achievements[]
  user_course_progress                                                                    user_course_progress[]
  user_lesson_progress                                                                    user_lesson_progress[]
  companies                                                                               companies?                      @relation(fields: [company_id], references: [id], onUpdate: NoAction)

  @@index([company_id], map: "idx_users_company_id")
}

model sections {
  id                  String          @id(map: "modules_pkey") @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  course_id           String          @db.Uuid
  title               String
  description         String?
  sort_order          Int             @default(0)
  required_section_id String?         @db.Uuid
  created_at          DateTime        @default(now()) @db.Timestamptz(6)
  updated_at          DateTime        @default(now()) @db.Timestamptz(6)
  lessons             lessons[]
  quizzes             quizzes[]
  section_items       section_items[]
  courses             courses         @relation(fields: [course_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "sections_course_id_fkey")
  sections            sections?       @relation("sectionsTosections", fields: [required_section_id], references: [id], onUpdate: NoAction, map: "modules_required_module_id_fkey")
  other_sections      sections[]      @relation("sectionsTosections")

  @@index([course_id], map: "idx_sections_course_id")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model section_items {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  section_id String   @db.Uuid
  item_type  String
  lesson_id  String?  @unique @db.Uuid
  quiz_id    String?  @unique @db.Uuid
  sort_order Int      @default(0)
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @db.Timestamptz(6)
  lessons    lessons? @relation(fields: [lesson_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  quizzes    quizzes? @relation(fields: [quiz_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  sections   sections @relation(fields: [section_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([section_id], map: "idx_section_items_section_id")
  @@index([section_id, sort_order], map: "idx_section_items_sort_order")
}

model knowledge_sources {
  id                                                String                          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  owner_user_id                                     String                          @db.Uuid
  title                                             String
  description                                       String?
  visibility                                        String                          @default("private")
  content                                           String                          @default("")
  status                                            String                          @default("draft")
  created_at                                        DateTime                        @default(now()) @db.Timestamptz(6)
  updated_at                                        DateTime                        @default(now()) @db.Timestamptz(6)
  knowledge_type                                    String                          @default("unknown")
  library_id                                        String?                         @db.Uuid
  created_by_user_id                                String?                         @db.Uuid
  updated_by_user_id                                String?                         @db.Uuid
  summary                                           String?
  language                                          String?
  domain                                            String?
  level                                             String?
  confidence                                        Float?
  tags                                              Json?
  keywords                                          Json?
  entities                                          Json?
  company_id                                        String?                         @db.Uuid
  courses                                           courses[]
  knowledge_analysis                                knowledge_analysis?
  knowledge_correction_requests                     knowledge_correction_requests[]
  knowledge_files                                   knowledge_files[]
  knowledge_graph                                   knowledge_graph?
  knowledge_share_links                             knowledge_share_links[]
  companies                                         companies?                      @relation(fields: [company_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users_knowledge_sources_created_by_user_idTousers users?                          @relation("knowledge_sources_created_by_user_idTousers", fields: [created_by_user_id], references: [id], onUpdate: NoAction)
  knowledge_libraries                               knowledge_libraries?            @relation(fields: [library_id], references: [id], onUpdate: NoAction)
  users_knowledge_sources_updated_by_user_idTousers users?                          @relation("knowledge_sources_updated_by_user_idTousers", fields: [updated_by_user_id], references: [id], onUpdate: NoAction)

  @@index([owner_user_id], map: "idx_knowledge_sources_owner_user_id")
  @@index([visibility], map: "idx_knowledge_sources_visibility")
  @@index([library_id], map: "idx_knowledge_sources_library_id")
  @@index([company_id], map: "idx_knowledge_sources_company_id")
}

model knowledge_files {
  id                  String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  knowledge_source_id String            @db.Uuid
  file_name           String
  file_type           String?
  file_size           Int?
  storage_path        String?
  extracted_text      String            @default("")
  status              String            @default("uploaded")
  created_at          DateTime          @default(now()) @db.Timestamptz(6)
  updated_at          DateTime          @default(now()) @db.Timestamptz(6)
  uploaded_by_user_id String?           @db.Uuid
  knowledge_sources   knowledge_sources @relation(fields: [knowledge_source_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users               users?            @relation(fields: [uploaded_by_user_id], references: [id], onUpdate: NoAction)

  @@index([knowledge_source_id], map: "idx_knowledge_files_knowledge_source_id")
  @@index([uploaded_by_user_id], map: "idx_knowledge_files_uploaded_by_user_id")
}

model knowledge_analysis {
  id                  String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  knowledge_source_id String            @unique @db.Uuid
  status              String            @default("pending")
  analysis_json       Json?
  model               String?
  prompt_version      String            @default("knowledge-analysis-v1")
  tokens_input        Int?
  tokens_output       Int?
  processing_ms       Int?
  error_message       String?
  created_at          DateTime          @default(now()) @db.Timestamptz(6)
  updated_at          DateTime          @default(now()) @db.Timestamptz(6)
  knowledge_sources   knowledge_sources @relation(fields: [knowledge_source_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([status], map: "idx_knowledge_analysis_status")
}

model knowledge_libraries {
  id                                                  String                               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  owner_user_id                                       String                               @db.Uuid
  parent_id                                           String?                              @db.Uuid
  name                                                String
  position                                            Int                                  @default(0)
  created_at                                          DateTime                             @default(now()) @db.Timestamptz(6)
  updated_at                                          DateTime                             @default(now()) @db.Timestamptz(6)
  created_by_user_id                                  String?                              @db.Uuid
  updated_by_user_id                                  String?                              @db.Uuid
  company_id                                          String?                              @db.Uuid
  visibility                                          String                               @default("restricted")
  chat_conversations                                  chat_conversations[]
  knowledge_activity                                  knowledge_activity[]
  knowledge_correction_requests                       knowledge_correction_requests[]
  knowledge_events                                    knowledge_events[]
  knowledge_imports                                   knowledge_imports[]
  companies                                           companies?                           @relation(fields: [company_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users_knowledge_libraries_created_by_user_idTousers users?                               @relation("knowledge_libraries_created_by_user_idTousers", fields: [created_by_user_id], references: [id], onUpdate: NoAction)
  users                                               users                                @relation(fields: [owner_user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  knowledge_libraries                                 knowledge_libraries?                 @relation("knowledge_librariesToknowledge_libraries", fields: [parent_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  other_knowledge_libraries                           knowledge_libraries[]                @relation("knowledge_librariesToknowledge_libraries")
  users_knowledge_libraries_updated_by_user_idTousers users?                               @relation("knowledge_libraries_updated_by_user_idTousers", fields: [updated_by_user_id], references: [id], onUpdate: NoAction)
  knowledge_library_permissions                       knowledge_library_permissions[]
  knowledge_library_team_permissions                  knowledge_library_team_permissions[]
  knowledge_share_links                               knowledge_share_links[]
  knowledge_sources                                   knowledge_sources[]
  knowledge_space_libraries                           knowledge_space_libraries[]

  @@unique([owner_user_id, name], map: "knowledge_libraries_root_unique", where: raw("(parent_id IS NULL)"))
  @@index([owner_user_id, parent_id], map: "idx_knowledge_libraries_owner_parent")
  @@index([owner_user_id], map: "idx_knowledge_libraries_owner_user_id")
  @@index([parent_id], map: "idx_knowledge_libraries_parent_id")
  @@index([company_id], map: "idx_knowledge_libraries_company_id")
  @@index([visibility], map: "idx_knowledge_libraries_visibility")
}

model chat_conversations {
  id                                                 String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  owner_user_id                                      String               @db.Uuid
  title                                              String               @default("Nueva conversación")
  scope_type                                         String               @default("all")
  scope_library_id                                   String?              @db.Uuid
  created_by_user_id                                 String?              @db.Uuid
  updated_by_user_id                                 String?              @db.Uuid
  created_at                                         DateTime             @default(now()) @db.Timestamptz(6)
  updated_at                                         DateTime             @default(now()) @db.Timestamptz(6)
  space_id                                           String?              @db.Uuid
  company_id                                         String?              @db.Uuid
  companies                                          companies?           @relation(fields: [company_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users_chat_conversations_created_by_user_idTousers users?               @relation("chat_conversations_created_by_user_idTousers", fields: [created_by_user_id], references: [id], onUpdate: NoAction)
  users_chat_conversations_owner_user_idTousers      users                @relation("chat_conversations_owner_user_idTousers", fields: [owner_user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  knowledge_libraries                                knowledge_libraries? @relation(fields: [scope_library_id], references: [id], onUpdate: NoAction)
  knowledge_spaces                                   knowledge_spaces?    @relation(fields: [space_id], references: [id], onUpdate: NoAction)
  users_chat_conversations_updated_by_user_idTousers users?               @relation("chat_conversations_updated_by_user_idTousers", fields: [updated_by_user_id], references: [id], onUpdate: NoAction)
  chat_messages                                      chat_messages[]

  @@index([owner_user_id], map: "idx_chat_conversations_owner_user_id")
  @@index([scope_library_id], map: "idx_chat_conversations_scope_library_id")
  @@index([space_id], map: "idx_chat_conversations_space_id")
  @@index([company_id], map: "idx_chat_conversations_company_id")
}

model chat_messages {
  id                 String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conversation_id    String             @db.Uuid
  user_id            String?            @db.Uuid
  role               String
  content            String
  sources_json       Json?
  model              String?
  tokens_input       Int?
  tokens_output      Int?
  created_at         DateTime           @default(now()) @db.Timestamptz(6)
  chat_conversations chat_conversations @relation(fields: [conversation_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users              users?             @relation(fields: [user_id], references: [id], onUpdate: NoAction)

  @@index([conversation_id], map: "idx_chat_messages_conversation_id")
  @@index([user_id], map: "idx_chat_messages_user_id")
}

model companies {
  id                  String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                String
  slug                String                @unique
  created_at          DateTime              @default(now()) @db.Timestamptz(6)
  updated_at          DateTime              @default(now()) @db.Timestamptz(6)
  chat_conversations  chat_conversations[]
  knowledge_activity  knowledge_activity[]
  knowledge_events    knowledge_events[]
  knowledge_imports   knowledge_imports[]
  knowledge_libraries knowledge_libraries[]
  knowledge_sources   knowledge_sources[]
  knowledge_spaces    knowledge_spaces[]
  knowledge_teams     knowledge_teams[]
  users               users[]
}

model knowledge_library_permissions {
  id                  String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  library_id          String              @db.Uuid
  user_id             String              @db.Uuid
  access_level        String              @default("read")
  created_at          DateTime            @default(now()) @db.Timestamptz(6)
  updated_at          DateTime            @default(now()) @db.Timestamptz(6)
  knowledge_libraries knowledge_libraries @relation(fields: [library_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users               users               @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([library_id, user_id])
}

model knowledge_space_libraries {
  id                  String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  space_id            String              @db.Uuid
  library_id          String              @db.Uuid
  created_at          DateTime            @default(now()) @db.Timestamptz(6)
  knowledge_libraries knowledge_libraries @relation(fields: [library_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  knowledge_spaces    knowledge_spaces    @relation(fields: [space_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([space_id, library_id])
  @@index([library_id], map: "idx_knowledge_space_libraries_library_id")
  @@index([space_id], map: "idx_knowledge_space_libraries_space_id")
}

model knowledge_space_permissions {
  id               String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  space_id         String           @db.Uuid
  user_id          String           @db.Uuid
  access_level     String           @default("read")
  created_at       DateTime         @default(now()) @db.Timestamptz(6)
  updated_at       DateTime         @default(now()) @db.Timestamptz(6)
  knowledge_spaces knowledge_spaces @relation(fields: [space_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users            users            @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([space_id, user_id])
  @@index([space_id], map: "idx_knowledge_space_permissions_space_id")
  @@index([user_id], map: "idx_knowledge_space_permissions_user_id")
}

model knowledge_spaces {
  id                                               String                        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  company_id                                       String?                       @db.Uuid
  name                                             String
  description                                      String?
  visibility                                       String                        @default("restricted")
  created_by_user_id                               String?                       @db.Uuid
  updated_by_user_id                               String?                       @db.Uuid
  created_at                                       DateTime                      @default(now()) @db.Timestamptz(6)
  updated_at                                       DateTime                      @default(now()) @db.Timestamptz(6)
  chat_conversations                               chat_conversations[]
